# ============================================
# Git 忽略文件配置
# 忽略缓存、系统文件、本地无关资源
# ============================================

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 编辑器/IDE 配置
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# 日志文件
*.log
npm-debug.log*

# 临时文件
*.tmp
*.temp
*.swp
*~

# 操作系统文件
*.directory

# 本地环境文件（可能包含敏感信息）
.env
.env.local
.env.*.local

# 构建输出（本项目无构建步骤，但预防性添加）
dist/
build/
out/

# 依赖目录（本项目使用 CDN，但预防性添加）
node_modules/

# 测试覆盖率
.coverage/

# 其他
.cache/
\n~$*\n*.tmp
